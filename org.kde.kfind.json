{
    "id": "org.kde.kfind",
    "rename-icon": "kfind",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "kfind",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--filesystem=host",
        "--device=dri"
    ],
    "cleanup": [
        "/share/doc",
        "/share/man",
        "/share/qlogging-categories6"
    ],
    "modules": [
        {
            "name": "kfind",
            "buildsystem": "cmake-ninja",
            "post-install": [
                "desktop-file-edit --remove-only-show-in=KDE /app/share/applications/${FLATPAK_ID}.desktop"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.0/src/kfind-26.04.0.tar.xz",
                    "sha256": "b35e4e216373b5d5cc14ce6b3efdf6d60362a99cad4f39249cfaef646c435b92",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/kfind-$version.tar.xz"
                    }
                }
            ]
        }
    ]
}
